# Copia questo file in ".env" e valorizzalo con le credenziali del tuo progetto Firebase.
# Le variabili con prefisso EXPO_PUBLIC_ sono incluse nel bundle client (non
# metterci mai segreti: quelli vanno nelle Cloud Functions come secrets, es.
# STRIPE_SECRET_KEY / STRIPE_WEBHOOK_SECRET tramite `firebase functions:secrets:set`).

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Chiave pubblicabile Stripe (usata lato client dal futuro StripeProvider).
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Google Maps Platform (Maps SDK Android + Routes API).
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
